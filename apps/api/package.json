{
  "name": "@linkpulse/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "prisma generate",
    "lint": "node --check src/server.js && node --check src/app.js",
    "test": "vitest run",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:studio": "prisma studio --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "ua-parser-js": "^2.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.1.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
