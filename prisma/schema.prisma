generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  links         Link[]
  refreshSessions RefreshSession[]

  @@map("users")
}

model Link {
  id          String    @id @default(cuid())
  userId      String?   @map("user_id")
  originalUrl String    @map("original_url")
  shortCode   String    @unique @map("short_code")
  customAlias String?   @unique @map("custom_alias")
  status      LinkStatus @default(active)
  clickCount  Int       @default(0) @map("click_count")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  clickEvents ClickEvent[]

  @@index([userId])
  @@index([shortCode])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([clickCount])
  @@map("links")
}

model ClickEvent {
  id         String   @id @default(cuid())
  linkId     String   @map("link_id")
  ipHash     String?  @map("ip_hash")
  visitorHash String? @map("visitor_hash")
  userAgent  String?  @map("user_agent")
  referrer   String?
  country    String?
  deviceType String?  @map("device_type")
  browser    String?
  operatingSystem String? @map("operating_system")
  clickedAt  DateTime @default(now()) @map("clicked_at")

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, clickedAt])
  @@index([linkId, visitorHash])
  @@index([browser])
  @@index([operatingSystem])
  @@index([deviceType])
  @@index([country])
  @@map("click_events")
}

model RefreshSession {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_sessions")
}

enum LinkStatus {
  active
  disabled
  deleted
}
